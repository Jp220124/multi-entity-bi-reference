# Copy this file to .env and fill in real values. Never commit .env.
# --------------------------------------------------------------------

# Required: Anthropic API key for Claude Haiku / Sonnet / Opus calls.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Model identifiers. Pinned to specific versions so runs are reproducible.
# The demo defaults are safe to leave as-is; override only if you have a
# specific version requirement.
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6
OPUS_MODEL=claude-opus-4-7

# L3 Extended Thinking budget in tokens. Higher = deeper reasoning, more cost.
# Calibrated empirically; default is a balanced starting point.
L3_THINKING_BUDGET_TOKENS=8000

# Context store backend. Options: sqlite (default), supabase, postgres.
CONTEXT_STORE=sqlite

# SQLite database path (used when CONTEXT_STORE=sqlite). Relative paths are
# resolved from the repository root.
SQLITE_PATH=./context/context.db

# Optional — only required when CONTEXT_STORE=supabase.
SUPABASE_URL=
SUPABASE_KEY=

# Logging level. DEBUG / INFO / WARNING / ERROR / CRITICAL.
LOG_LEVEL=INFO
